# --- Standalone / self-hosted ---
# Comma-separated URLs of data files to auto-import on startup.
# Relative URLs are resolved from the build output; absolute URLs can be remote.
# Supported: .json (r4 backup), .txt (r4 download), .m3u/.m3u8
# Example: PUBLIC_SEED_URLS=/data/mychannel.txt,https://cdn.example.com/backup.json
#PUBLIC_SEED_URLS=

# --- Optional branding overrides (all have sane defaults) ---
#PUBLIC_APP_NAME=Radio4000
#PUBLIC_APP_SHORT_NAME=R4
#PUBLIC_APP_URL=https://beta.radio4000.com
#PUBLIC_APP_DESCRIPTION=Collect, curate, play and share your own radio channel
#PUBLIC_APP_PLAYER_URL=https://r5.i4k.workers.dev
#PUBLIC_APP_CLOUDINARY_URL=https://res.cloudinary.com/radio4000
#PUBLIC_APP_LEGAL_URL=https://legal.radio4000.com
#PUBLIC_APP_CHAT_URL=https://matrix.to/#/#radio4000:matrix.org

YOUTUBE_API_KEY=
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=

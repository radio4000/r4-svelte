		"@tanstack/svelte-db": "^0.1.72",
		"@tanstack/svelte-query": "^6.0.18",
		"@tanstack/svelte-query-devtools": "^6.0.4",
		"@types/yargs": "^17.0.35",
		"adze": "^2.3.0",
		"feed": "^5.2.0",
		"filenamify": "^7.0.1",
		"fuzzysort": "^3.1.0",
		"gsap": "^3.14.2",
		"idb-keyval": "^6.2.2",
		"leaflet": "^1.9.4",
		"lil-gui": "^0.21.0",
		"luxon": "^3.7.2",
		"marked": "^17.0.3",
		"media-chrome": "^4.18.0",
		"media-now": "^2.2.2",
		"obra-icons-svelte": "^1.23.1",
